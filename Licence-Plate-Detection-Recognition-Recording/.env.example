# Example .env file for License Plate Detection System
# Copy this to .env and adjust values as needed

# Operation Mode
MODE=image                          # "image" or "camera"
IMAGE_PATH=samples/test.jpg        # Required if MODE=image

# Backend API Configuration
BACKEND_BASE=http://localhost:8000
EMPLOYEE_USER=ninh1
EMPLOYEE_PASS=ninh1

# Camera Configuration (for MODE=camera)
CAM_INDEX=0

# Model Configuration
PLATE_MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.7

# Application Settings
DRY_RUN=true                       # Set to "false" to POST to backend
OUTPUT_DIR=outputs
SAVE_IMAGES=true
LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API Settings
API_TIMEOUT=30
API_MAX_RETRIES=3
API_RETRY_DELAY=1.0
