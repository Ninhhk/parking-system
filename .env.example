# Backend API Configuration
NODE_ENV=development
PORT=5000
# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=parking_lot

SALT=barking-lot
SESSION_SECRET=your-secret-key
CLIENT_URL=http://localhost:3000

# Session Configuration
# SESSION_SECRET=your-secret-key-here

# License Plate Detection Service Configuration
# URL where the Python LPD service is running
LPD_SERVICE_URL=http://localhost:5000

# Timeout for LPD API requests (in milliseconds)
LPD_TIMEOUT=30000

# Enable/disable LPD feature
LPD_ENABLED=true

# PayOS Configuration
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/employee/checkout
PAYOS_CANCEL_URL=http://localhost:3000/employee/checkout
PAYOS_WEBHOOK_PATH=/api/payments/payos/webhook
