# Backend API Configuration
NODE_ENV=development
PORT=5000
# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=parking_lot
# Host machine port mapped to Docker Postgres 5432
POSTGRES_HOST_PORT=55432

SALT=barking-lot
SESSION_SECRET=your-secret-key
CLIENT_URL=http://localhost:3000

# Session Configuration
# SESSION_SECRET=your-secret-key-here

# License Plate Detection Service Configuration
# URL where the Python LPD service is running
LPD_API_URL=http://localhost:8000

# Timeout for LPD API requests (in milliseconds)
LPD_TIMEOUT=30000

# Enable/disable LPD feature
LPD_ENABLED=true

# Model paths (resolved inside the container via volume mount)
LPD_STAGE1_MODEL_PATH=/app/repo5/model/license_plate_detector.pt
LPD_STAGE2_MODEL_PATH=/app/repo5/model/LP_ocr_yolov8.pt

# PayOS Configuration
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/employee/checkout
PAYOS_CANCEL_URL=http://localhost:3000/employee/checkout
PAYOS_QR_TTL_MINUTES=15
PAYOS_WEBHOOK_PATH=/api/payments/payos/webhook
PAYMENT_INTENT_V2_ENABLED=true

# Edge Ingest Configuration
# Use a strong non-empty key outside local development.
EDGE_INGEST_API_KEY=
EDGE_LPD_CORRELATION_WINDOW_SECONDS=5
EDGE_MONITOR_DEFAULT_PAGE_SIZE=20

# RFID Kiosk Configuration
RFID_CHECKIN_ENABLED=true
NEXT_PUBLIC_KIOSK_MODULE_READER=true
NEXT_PUBLIC_KIOSK_MODULE_VEHICLE_FORM=true
NEXT_PUBLIC_KIOSK_MODULE_RESULT=true
NEXT_PUBLIC_KIOSK_MODULE_GATE_STATUS=true
NEXT_PUBLIC_KIOSK_MODULE_RECENT_EVENTS=true
